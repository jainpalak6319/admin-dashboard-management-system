# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# (e.g., mongodb://localhost:27017/your_db_name or your Atlas connection string template)
MONGO_URI=your_mongodb_connection_string_here

# JWT Authentication Secrets
# (Put a note telling users to generate a strong random string here)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d